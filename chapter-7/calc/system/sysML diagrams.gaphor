<SysML:Requirement id="7cb2fce2-3675-11f1-9166-50ebf6e4fe33">
<name>
<val>special commands</val>
</name>
<owningPackage>
<ref refid="932cf235-3660-11f1-a6eb-50ebf6e4fe33"/>
</owningPackage>
<package>
<ref refid="932cf235-3660-11f1-a6eb-50ebf6e4fe33"/>
</package>
<presentation>
<reflist>
<ref refid="7cb33dc5-3675-11f1-affb-50ebf6e4fe33"/>
</reflist>
</presentation>
<targetDirectedRelationshipPropertyPath_>
<reflist>
<ref refid="09f6b331-36a1-11f1-81a4-50ebf6e4fe33"/>
</reflist>
</targetDirectedRelationshipPropertyPath_>
<text>
<val>it shall support following special commands; case matters:
	General:
	CLEAR - for clearing the stack 
	TOP - get top element
	DUP - duplicate top element	
	SWAP - swap top 2 elements
	EXIT - quit the program

	Math:
	SIN - sinus of top number
	COS - cosine of top number
	EXP - e powered by top number
	POW - power operation of top 2 numbers
</val>
</text>
</SysML:Requirement>
<SysML:RequirementItem id="7cb33dc5-3675-11f1-affb-50ebf6e4fe33">
