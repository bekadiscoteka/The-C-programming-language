<SysML:Requirement id="80ba6ee6-36a3-11f1-9e7a-50ebf6e4fe33">
<name>
<val>number format</val>
</name>
<owningPackage>
<ref refid="932cf235-3660-11f1-a6eb-50ebf6e4fe33"/>
</owningPackage>
<package>
<ref refid="932cf235-3660-11f1-a6eb-50ebf6e4fe33"/>
</package>
<presentation>
<reflist>
<ref refid="80bae4e1-36a3-11f1-a43d-50ebf6e4fe33"/>
</reflist>
</presentation>
<targetDirectedRelationshipPropertyPath_>
<reflist>
<ref refid="d27e3a55-36a3-11f1-a3fb-50ebf6e4fe33"/>
</reflist>
</targetDirectedRelationshipPropertyPath_>
<text>
<val>it shall support following formats as input number:
float 32 bit, examples: 3.4, 1.5
whole numbers as int (C machine dependent): examples: 3 4 5</val>
